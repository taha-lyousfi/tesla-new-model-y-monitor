# Exact Tesla France new Model Y search requested by Fahd.
POSTAL_CODE=92360
SEARCH_LAT=48.8127
SEARCH_LNG=2.2382
SEARCH_RANGE=0
TOP_N=20

# Five minutes reduces the chance of missing short-lived inventory.
CHECK_INTERVAL_MINUTES=5
RETRY_DELAY_MINUTES=2
MAX_RETRY_DELAY_MINUTES=30
FAILURE_ALERT_THRESHOLD=3
NOTIFY_ON_FIRST_RUN=true
HEADLESS=true
BROWSER_CHANNEL=chrome

# Gmail SMTP. Run `npm run setup` instead of editing these manually.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sender@gmail.com
SMTP_PASSWORD=
EMAIL_FROM=Tesla Model Y Monitor <sender@gmail.com>
EMAIL_TO=recipient@example.com

# Optional authenticated proxy if a server IP is blocked by Tesla.
TESLA_PROXY_SERVER=
TESLA_PROXY_USERNAME=
TESLA_PROXY_PASSWORD=
